<%- include('partials/header') %>

    <section class="organizations">

        <h2>Organizations</h2>

        <p class="intro">
            Explore organizations that are making a positive impact in communities around the world.
        </p>

        <div class="cards">

            <div class="card">
                <img src="/images/organization.webp" alt="Community organization">
                <h3>Helping Communities</h3>
                <p>
                    Support organizations that provide food, shelter, and assistance to families.
                </p>
            </div>

            <div class="card">
                <img src="/images/plantingatree.webp" alt="Planting trees">
                <h3>Environmental Care</h3>
                <p>
                    Participate in projects focused on planting trees and protecting nature.
                </p>
            </div>

            <div class="card">
                <img src="/images/trash.webp" alt="Cleaning parks">
                <h3>Community Cleanup</h3>
                <p>
                    Join volunteers working together to keep parks and neighborhoods clean.
                </p>
            </div>

        </div>

    </section>

    <%- include('partials/footer') %>